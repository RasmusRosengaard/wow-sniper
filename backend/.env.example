# Blizzard API credentials — create at https://develop.battle.net/
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here

# WoW region: us | eu | kr | tw
WOW_REGION=us

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sniper:sniper@localhost:5432/wowsniper

# WebSocket server
WS_HOST=0.0.0.0
WS_PORT=8000

# Snipe tier thresholds (fraction of market price; e.g. 0.6 = 40% below market)
THRESHOLD_LOW=0.80
THRESHOLD_MEDIUM=0.60
THRESHOLD_ULTRA=0.40

# How many days of price history to use for market baseline
PRICE_HISTORY_DAYS=7

# Minimum number of historical data points before classifying snipes
MIN_PRICE_SAMPLES=3
