{
  "name": "wow-sniper",
  "version": "1.0.0",
  "description": "WoW Auction House Sniper",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist:win": "electron-vite build && electron-builder --win",
    "generate-icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "framer-motion": "^11.18.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.1",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.9",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.wowsniper.app",
    "productName": "WoW Sniper",
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": ["out/**/*"],
    "directories": {
      "output": "dist"
    }
  }
}
